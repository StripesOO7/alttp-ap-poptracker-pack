                        "rows": [
                            [
                                "gt_access", //gt crystal  count
                                "small_keys"
                            ],
                            [
                                "ganon_killable", //ganon crystal count
                                "big_keys"
                            ],
                            [
                                "triforce_pieces_needed",
                                "swordless"
